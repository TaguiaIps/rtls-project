{
  "expo": {
    "name": "RTLS Analytics Platform",
    "slug": "rtls-taguia",
    "scheme": "rtls",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow RTLS Analytics Platform to scan gateway and tag QR codes.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taguia.rtls.analytics",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.taguia.rtls.analytics"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "a8803e18-189c-40d4-985c-ab65217d9756"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/a8803e18-189c-40d4-985c-ab65217d9756"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "hugodepaulas-organization"
  }
}
